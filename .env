# Copia este archivo a ".env" para probar en local con `vercel dev`.
# En producción, estas mismas variables van en:
# Vercel → tu proyecto → Settings → Environment Variables

# Clave para entrar a /admin.html y a la API de listado/export.
ADMIN_KEY=Lind@2304

# Dominio(s) permitidos para llamar la API desde otro origen.
# Como front y API viven en el mismo dominio en este proyecto, "*" es
# suficiente casi siempre; solo ajústalo si vas a llamar la API desde
# otro sitio distinto.
ALLOWED_ORIGIN=*

# --- Almacenamiento persistente (obligatorio en producción) ---
# Crea una base gratis en https://upstash.com (o desde el marketplace de
# Vercel: Storage → Marketplace Database Providers → Upstash) y pega aquí
# la URL y el token REST que te dan.
UPSTASH_REDIS_REST_URL=https://on-koi-176019.upstash.io
UPSTASH_REDIS_REST_TOKEN=gQAAAAAAAq-TAAIgcDE1MjA4ZjU4YWRkOWI0NzhjOWJmYzY4OTAzZTFhNWY1NQ
